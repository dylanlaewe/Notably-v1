def process_upload(upload_id: str, object_key: str) -> None:\
db: Session = SessionLocal()\
try:\
u = db.get(Upload, uuid.UUID(upload_id))\
if not u:\
return\
u.status = UploadStatus.PROCESSING\
db.add(u)\
db.commit()\
\
# Simulate work\
time.sleep(2)\
\
# Create transcript + segments (fake)\
t = Transcript(upload_id=u.id, language="en")\
db.add(t)\
db.flush()  # so t.id exists\
