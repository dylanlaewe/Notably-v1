import hashlib\
from typing import Tuple\
\
BUF_SIZE = 1024 * 1024\
\
def stream_sha256_and_size(fileobj) -> Tuple[str, int]:\
h = hashlib.sha256()\
total = 0\
while True:\
chunk = fileobj.read(BUF_SIZE)\
if not chunk:\
break\
total += len(chunk)\
h.update(chunk)\
return h.hexdigest(), total\
\
\
