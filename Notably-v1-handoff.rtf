);\
\
create table transcript_segment (\
id bigserial primary key,\
transcript_id uuid references transcript(id) on delete cascade,\
t_start numeric not null,\
t_end numeric not null,\
text text not null\
);\
create index idx_segment_transcript on transcript_segment(transcript_id);\
create index idx_segment_time on transcript_segment(transcript_id, t_start);\
\
create table summary (\
id uuid primary key,\
meeting_id uuid references meeting(id) on delete cascade,\
created_at timestamptz not null default now()\
);\
\
create table summary_bullet (\
id uuid primary key,\
summary_id uuid references summary(id) on delete cascade,\
text text not null\
);\
\
create table bullet_citation (\
summary_bullet_id uuid references summary_bullet(id) on delete cascade,\
segment_id bigint references transcript_segment(id) on delete cascade,\
primary key (summary_bullet_id, segment_id)\
);\
\
create table action_item (\
id uuid primary key,\
meeting_id uuid references meeting(id) on delete cascade,\
text text not null\
);\
\
create table action_item_assignee (\
action_item_id uuid references action_item(id) on delete cascade,\
user_id uuid references app_user(id) on delete cascade,\
primary key (action_item_id, user_id)\
);\
\
create table tag (\
id uuid primary key,\
team_id uuid references team(id) on delete cascade,\
name text not null\
);\
\
create table meeting_tag (\
meeting_id uuid references meeting(id) on delete cascade,\
tag_id uuid references tag(id) on delete cascade,\
primary key (meeting_id, tag_id)\
);\
\
create table user_preference (\
user_id uuid primary key references app_user(id) on delete cascade,\
theme text check (theme in ('light','dark')) default 'light',\
language text default 'en',\
notifications jsonb default '\{\}'::jsonb\
);\
\
