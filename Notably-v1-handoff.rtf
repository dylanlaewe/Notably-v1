version: "3.9"\
\
services:\
  postgres:\
    image: postgres:16-alpine\
    container_name: notably_postgres\
    environment:\
      POSTGRES_USER: notably\
      POSTGRES_PASSWORD: notably\
      POSTGRES_DB: notably_dev\
    ports:\
