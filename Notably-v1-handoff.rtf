db.flush()\
\
b1 = SummaryBullet(summary_id=summary.id, text="MVP scope confirmed and timelines aligned.")\
b2 = SummaryBullet(summary_id=summary.id, text="Next step is wiring upload to background job.")\
db.add_all([b1, b2])\
db.flush()\
