from fastapi import FastAPI\
from .api.v1.uploads import router as uploads_router\
from .db import init_db\
from .services.minio_client import init_buckets\
\
app = FastAPI(title="Notably API", version="0.1.0")\
\
@app.on_event("startup")\
async def startup() -> None:\
# Create tables and ensure buckets exist\
init_db()\
await init_buckets()\
\
@app.get("/health")\
def health():\
return \{"ok": True\}\
\
app.include_router(uploads_router, prefix="/v1", tags=["uploads"])\
\
