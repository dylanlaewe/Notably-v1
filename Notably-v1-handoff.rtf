])\
\
u.status = UploadStatus.DONE\
db.add(u)\
db.commit()\
except Exception as e:\
if u:\
u.status = UploadStatus.FAILED\
u.error = str(e)\
db.add(u)\
db.commit()\
raise\
finally:\
db.close()\
